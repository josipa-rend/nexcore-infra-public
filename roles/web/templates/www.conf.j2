<VirtualHost *:{{ httpd_port }}>
    ServerName {{ wordpress_domain }}
    DocumentRoot {{ wordpress_path }}

    <Directory "{{ wordpress_path }}">
        AllowOverride All

        Require all granted
    </Directory>

    ErrorLog /var/log/httpd/wordpress_error.log
    CustomLog /var/log/httpd/wordpress_access.log combined
</VirtualHost>